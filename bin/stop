#!/usr/bin/env bash
ROOT="$(cd "$(dirname "$0")/.." && pwd)"
PID_FILE="$ROOT/bin/.server.pid"

if [ ! -f "$PID_FILE" ]; then
  echo "No server is running."
  exit 0
fi

PID=$(cat "$PID_FILE")
if kill -0 "$PID" 2>/dev/null; then
  kill "$PID"
  echo "Server stopped (PID $PID)"
else
  echo "No running server found for PID $PID"
fi

rm -f "$PID_FILE"
